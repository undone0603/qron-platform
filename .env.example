# ══════════════════════════════════════════════════════════════════════════════
# QRON PLATFORM — Environment Variables
# Copy to .env.local for local development. Never commit real values.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...         # Server-only. Never expose client-side.

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://qron.space   # Canonical origin used in emails/links
ADMIN_EMAIL=admin@qron.space             # Recipient of daily executive reports
ADMIN_DASHBOARD_KEY=                     # Bearer token for /api/admin/* routes

# ── Cron / Automation ─────────────────────────────────────────────────────────
CRON_SECRET=                             # Bearer token required by all /api/automation/cron* routes
HEALTH_SECRET=                           # Optional: secures GET /api/health

# ── Cloudflare Edge Workers ───────────────────────────────────────────────────
QRON_WORKER_URL=https://qron-ai-api.undone-k.workers.dev   # Main AI generation worker

# ── AI / Image Generation ─────────────────────────────────────────────────────
HUGGINGFACE_TOKEN=hf_...                 # HF Inference API token (primary key name)
HF_TOKEN=hf_...                          # Alias — code checks both; set one or both

# ── Email (fallback chain: Gmail → Resend → Brevo → SendGrid) ─────────────────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=                      # 16-char Google App Password (spaces stripped)
RESEND_API_KEY=re_...
BREVO_API_KEY=xkeysib-...
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=ops@qron.space

# ── CRM / Marketing ───────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=pat-na1-...         # HubSpot Private App token
MAKE_LEAD_WEBHOOK_URL=                   # Make.com (Integromat) webhook for lead capture
APOLLO_API_KEY=                          # Apollo.io for lead enrichment (optional)
BUFFER_WEBHOOK_URL=                      # Buffer social scheduling webhook

# ── AgentZ — Autonomous Outreach & Growth Engine ──────────────────────────────
# AgentZ runs the outreach-generator.ts and grant-writer-agent.ts scripts
# via GitHub Actions workflow_dispatch. Triggered nightly by the daily cycle.
GITHUB_PAT=github_pat_...               # PAT with 'workflow' scope (repo: qron-platform)
GITHUB_OWNER=undone0603
GITHUB_REPO=qron-platform

# ── Webhooks / Alerts ─────────────────────────────────────────────────────────
SECURITY_ALERTS_WEBHOOK_URL=            # Discord/Slack webhook for industrial anomalies
DAO_COMMUNITY_WEBHOOK_URL=              # Discord/Telegram webhook for governance alerts

# ── Payments ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...           # Stripe secret key (use sk_test_ for dev)
STRIPE_WEBHOOK_SECRET=whsec_...         # Stripe webhook signing secret

# ── Blockchain / Web3 ─────────────────────────────────────────────────────────
BLOCKCHAIN_PRIVATE_KEY=0x...            # Signing wallet private key (KEEP SECRET)
MINTER_PRIVATE_KEY=0x...               # NFT minting wallet private key
DEMO_WALLET_ADDRESS=0x...              # Public demo wallet address (safe to expose)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
AUTHICHAIN_CONTRACT_ADDRESS=0x...
QRON_NFT_CONTRACT_ADDRESS=0x...
AUTHICHAIN_API_URL=https://api.authichain.com
AUTHICHAIN_API_SECRET=
AUTHICHAIN_KEY=

# ── Thirdweb ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
NEXT_PUBLIC_THIRDWEB_CHAIN=polygon
THIRDWEB_SECRET_KEY=
THIRDWEB_MINTER_KEY=

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                     # Used by /api/telegram for bot commands

# ── Cloudflare Workers (set via wrangler secrets, not .env) ───────────────────
# CLOUDFLARE_API_TOKEN=                 # Managed in GitHub Secrets for CI/CD
# CLOUDFLARE_ACCOUNT_ID=               # Managed in GitHub Secrets for CI/CD
