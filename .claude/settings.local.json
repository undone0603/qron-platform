{
  "permissions": {
    "allow": [
      "PowerShell(npx tsc --noEmit 2>&1 | Select-Object -First 200)",
      "PowerShell(npx tsc --noEmit; \"EXIT:$LASTEXITCODE\")",
      "PowerShell(npx eslint . --max-warnings 0; \"EXIT:$LASTEXITCODE\")",
      "PowerShell(npx tsc --noEmit; \"TSC_EXIT:$LASTEXITCODE\")",
      "PowerShell(npx tsc --noEmit 2>&1 | Out-String; \"TSC_EXIT:$LASTEXITCODE\")",
      "PowerShell(npx eslint . 2>&1 | Out-String; \"ESLINT_EXIT:$LASTEXITCODE\")",
      "PowerShell(npx next build 2>&1 | Select-Object -Last 60; \"BUILD_EXIT:$LASTEXITCODE\")",
      "PowerShell(npx next build 2>&1 | Select-Object -Last 12; \"BUILD_EXIT:$LASTEXITCODE\")",
      "PowerShell(npx tsc --noEmit; \"TSC:$LASTEXITCODE\"; npx eslint . 2>&1 | Out-String; \"ESLINT:$LASTEXITCODE\")"
    ]
  }
}
